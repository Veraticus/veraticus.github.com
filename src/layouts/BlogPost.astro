---
import Base from "./Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  readonly frontmatter: {
    readonly title: string;
    readonly date: string;
    readonly tags: readonly string[];
  };
}

const { frontmatter } = Astro.props;

const formattedDate = new Date(frontmatter.date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Base title={`${frontmatter.title} | Josh Symonds`}>
  <Header />
  <main>
    <article class="prose">
      <header class="post-header">
        <h1>{frontmatter.title}</h1>
        <time datetime={frontmatter.date}>{formattedDate}</time>
        <div class="tags">
          {frontmatter.tags.map((tag) => (
            <span class="tag-pill">{tag}</span>
          ))}
        </div>
      </header>
      <slot />
    </article>
  </main>
  <Footer />
</Base>

<style>
  .prose {
    max-width: 72ch;
    margin-inline: auto;
    padding-inline: 1.5rem;
    padding-block: 2rem;
    line-height: 1.75;
    color: var(--black);
  }

  .post-header {
    margin-block-end: 2.5rem;
    padding-block-end: 1.5rem;
    border-block-end: 3px solid var(--black);
    position: relative;
  }

  .post-header::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -6px;
    width: 10px;
    height: 10px;
    background: var(--teal);
    border: 2px solid var(--black);
    border-radius: 50%;
  }

  .post-header h1 {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 800;
    line-height: 1.2;
    margin-block-end: 0.75rem;
    color: var(--black);
  }

  .post-header time {
    display: block;
    color: var(--teal);
    font-size: 0.95rem;
    font-weight: 700;
    margin-block-end: 0.75rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-pill {
    display: inline-block;
    padding: 0.2em 0.7em;
    border-radius: var(--radius-full);
    background: var(--bg-surface);
    color: var(--black);
    font-size: 0.8rem;
    font-weight: 500;
    border: 2px solid var(--black);
  }

  /* Prose content styles */
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    font-family: var(--font-heading);
    margin-block-start: 2em;
    margin-block-end: 0.75em;
    line-height: 1.3;
    color: var(--black);
  }

  .prose :global(h2) {
    font-size: 1.75rem;
  }

  .prose :global(h3) {
    font-size: 1.4rem;
  }

  .prose :global(h4) {
    font-size: 1.15rem;
  }

  .prose :global(a) {
    color: var(--teal);
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 0.15em;
  }

  .prose :global(a:hover) {
    color: var(--coral);
  }

  .prose :global(pre) {
    background: #f0f0ec;
    border: 2px solid var(--black);
    border-radius: var(--radius-md);
    padding: 1.25rem;
    overflow-x: auto;
    margin-block: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--black);
  }

  .prose :global(pre > code) {
    background: none;
    padding: 0;
    border: none;
    color: inherit;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
  }

  .prose :global(:not(pre) > code) {
    background: #f0f0ec;
    padding: 0.15em 0.35em;
    border-radius: var(--radius-sm);
    border: 2px solid var(--black);
    color: var(--black);
  }

  .prose :global(blockquote) {
    border-inline-start: 4px solid var(--teal);
    padding-inline-start: 1.25rem;
    margin-inline: 0;
    margin-block: 1.5rem;
    background: #f0f0ec;
    padding: 1rem 1.25rem;
    color: var(--text-muted);
    font-style: italic;
    position: relative;
  }

  .prose :global(blockquote)::before {
    content: "";
    position: absolute;
    top: -4px;
    left: -4px;
    width: 8px;
    height: 8px;
    background: var(--coral);
    border: 2px solid var(--black);
    transform: rotate(45deg);
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    border: 2px solid var(--black);
    margin-block: 1.5rem;
  }

  .prose :global(p) {
    margin-block: 1.25rem;
    max-width: none;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-inline-start: 1.5rem;
    margin-block: 1.25rem;
  }

  .prose :global(li) {
    margin-block: 0.35rem;
  }

  .prose :global(hr) {
    border: none;
    height: 3px;
    background: var(--black);
    margin-block: 2rem;
    position: relative;
  }

  .prose :global(hr)::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 10px;
    height: 10px;
    background: var(--yellow);
    border: 2px solid var(--black);
    border-radius: 50%;
  }

  /* Memphis-styled table */
  .prose :global(table) {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    border: 3px solid var(--black);
    box-shadow: 4px 4px 0 var(--black);
    background: var(--white);
    margin-block: 2rem;
    font-family: var(--font-body);
  }

  .prose :global(thead) {
    /* Soft tinted teal; full-strength --teal was too dark behind bold text. */
    background: color-mix(in srgb, var(--teal) 45%, white);
  }

  .prose :global(th) {
    padding: 0.6rem 0.9rem;
    font-weight: 700;
    text-align: left;
    color: var(--black);
    border-bottom: 3px solid var(--black);
    border-right: 2px solid var(--black);
    font-family: var(--font-heading);
    letter-spacing: -0.01em;
  }
  .prose :global(th:last-child) {
    border-right: none;
  }

  .prose :global(td) {
    padding: 0.55rem 0.9rem;
    border-top: 2px solid rgba(26, 26, 26, 0.12);
    border-right: 2px solid rgba(26, 26, 26, 0.12);
    color: var(--black);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }
  .prose :global(tr:first-child td) {
    border-top: none;
  }
  .prose :global(td:last-child) {
    border-right: none;
  }
  .prose :global(tbody tr:nth-child(even)) {
    background: rgba(26, 26, 26, 0.03);
  }

  .prose :global(td:first-child) {
    font-family: var(--font-body);
    font-weight: 500;
  }

  /* `**N MB**` in the source becomes <strong> inside a td -- render as a yellow pill */
  .prose :global(td strong) {
    display: inline-block;
    background: var(--yellow);
    padding: 0.05em 0.4em;
    border: 2px solid var(--black);
    box-shadow: 2px 2px 0 var(--black);
    font-weight: 700;
    font-family: var(--font-mono);
    line-height: 1.2;
  }

  /* Memphis squiggle underline under section headings, tiled as a data-URI
     SVG so the wave keeps its aspect ratio regardless of heading width. */
  .prose :global(h2)::after {
    content: '';
    display: block;
    height: 0.45em;
    margin-top: 0.2em;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 220 14'><path d='M2 7 Q14 2 26 7 Q38 12 50 7 Q62 2 74 7 Q86 12 98 7 Q110 2 122 7 Q134 12 146 7 Q158 2 170 7 Q182 12 194 7 Q206 2 218 7' fill='none' stroke='%232ec4b6' stroke-width='4' stroke-linecap='round'/></svg>");
    background-repeat: repeat-x;
    background-position: left center;
    background-size: auto 100%;
  }

  /* H3 shrinks to its text width so the squiggle sits tight under "The Dream"
     rather than spanning the whole column. */
  .prose :global(h3) {
    display: inline-block;
    max-width: 100%;
  }
  .prose :global(h3)::after {
    content: '';
    display: block;
    height: 0.38em;
    margin-top: 0.15em;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 220 14'><path d='M2 7 Q14 2 26 7 Q38 12 50 7 Q62 2 74 7 Q86 12 98 7 Q110 2 122 7 Q134 12 146 7 Q158 2 170 7 Q182 12 194 7 Q206 2 218 7' fill='none' stroke='%23ffd166' stroke-width='3' stroke-linecap='round'/></svg>");
    background-repeat: repeat-x;
    background-position: left center;
    background-size: auto 100%;
  }
</style>
